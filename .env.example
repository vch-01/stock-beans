# Set at least one of these for live stock data
# Alpaca (recommended - best free tier, 200 req/min)
# VITE_ALPACA_API_KEY=your_alpaca_api_key_here
# VITE_ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Finnhub (60 req/min)
# VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage (25 req/day - very limited)
# VITE_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
