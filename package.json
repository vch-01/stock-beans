{
  "name": "stock-valuation-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src/",
    "prepare": "husky install"
  },
  "dependencies": {
    "axios": "^1.5.1",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.6.2",
    "vite": "^5.4.1",
    "vite-plugin-solid": "^2.10.0",
    "vitest": "^1.4.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,css,md,json,html}": [
      "biome check --write --no-errors-on-unmatched",
      "git add"
    ]
  }
}
